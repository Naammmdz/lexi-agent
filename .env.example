# =============================================
# Vietnamese Legal Chatbot — mẫu cấu hình
# Sao chép: cp .env.example .env
# =============================================

# --- Retrieval (cấu hình IR tốt nhất đã benchmark) ---
USE_MERGED_CORPUS=1
HYBRID_FUSION=rrf
USE_WIDE_RETRIEVAL_POOL=1

# --- LLM (Ollama — chat / QA) ---
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_BACKEND=ollama
CHAT_MAX_ARTICLES=3
CHAT_MAX_CHARS_PER_ARTICLE=900
CHAT_MAX_NEW_TOKENS=512
CHAT_INCLUDE_DISCLAIMER=true
OLLAMA_NUM_CTX=8192

# --- Reranker (tắt trên Mac UI để tránh treo; bật trên GPU server) ---
ENABLE_RERANKING=0
RERANKER_DEVICE=cpu

# --- Qdrant (để trống = localhost:6333) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- UI ---
UI_MODE=lexi
LEXI_HOST=127.0.0.1
LEXI_PORT=7860

# --- Tuỳ chọn: Gemini / Google Search fallback ---
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=
# GOOGLE_CSE_API_KEY=
